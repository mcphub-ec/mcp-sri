# ─── SRI MCP Server ────────────────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores REALES antes de usar.
#   cp .env.example .env && chmod 600 .env
#
# ⚠️  NUNCA subas .env ni los archivos de certs/ al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor MCP ─────────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8002
# Opciones: sse | http_stream
MCP_TRANSPORT_MODE=sse

# ── Ambiente SRI ─────────────────────────────────────────────────────────────
# Valores: TEST | PRODUCTION
# ⚠️  PRODUCTION envía comprobantes reales al SRI — efecto legal e irreversible.
SRI_ENVIRONMENT=TEST

# ── Certificado Digital ──────────────────────────────────────────────────────
# Ruta al archivo .p12 PKCS#12 (certificado de firma electrónica del SRI).
# Coloca tu certificado en la carpeta certs/ (está ignorada por git).
CERTIFICATE_PATH=./certs/firma.p12
CERTIFICATE_PASSWORD=

# ── Datos del Emisor ─────────────────────────────────────────────────────────
# RUC de 13 dígitos del emisor de facturas.
EMITTER_RUC=
EMITTER_BUSINESS_NAME=
EMITTER_TRADE_NAME=
EMITTER_ADDRESS=
EMITTER_ESTABLISHMENT_CODE=001
EMITTER_EMISSION_POINT_CODE=001
# SI | NO
EMITTER_OBLIGADO_CONTABILIDAD=NO

# ── URLs del SRI (valores por defecto — no es necesario modificar) ────────────
# SRI_RECEPTION_URL_TEST=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline?wsdl
# SRI_AUTHORIZATION_URL_TEST=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/AutorizacionComprobantesOffline?wsdl
# SRI_RECEPTION_URL_PROD=https://cel.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline?wsdl
# SRI_AUTHORIZATION_URL_PROD=https://cel.sri.gob.ec/comprobantes-electronicos-ws/AutorizacionComprobantesOffline?wsdl

# ── Microservicio de firma Java ───────────────────────────────────────────────
# URL interna del servicio de firma (al usar docker-compose, no cambiar).
# SIGNING_SERVICE_URL=http://signing-service:18081
